{
    "name": "cuk/cuk-admin",
    "description": "Système de Gestion Universitaire - Centre Universitaire de Koulamoutou",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ext-pdo_mysql": "*",
        "ext-mbstring": "*",
        "ext-fileinfo": "*",
        "ext-redis": "*",
        "dompdf/dompdf": "^2.0",
        "phpoffice/phpspreadsheet": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "CUK\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "scripts": {
        "serve": "php -S localhost:8000",
        "migrate": "php database/migrate.php migrate",
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true
    }
}
