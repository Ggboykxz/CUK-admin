# CUK-Admin - Configuration production
# Copier en .env et modifier

APP_ENV=production
APP_DEBUG=false

# Base de données MySQL
DB_DRIVER=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=cuk_admin
DB_USER=cuk_user
DB_PASSWORD=chang3_m3_n0w!

# Redis (sessions)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PREFIX=cuk_session:

# Maintenance
MAINTENANCE_MODE=false

# Sécurité
CSRF_TOKEN_LIFETIME=7200
SESSION_LIFETIME=7200
RATE_LIMIT_ATTEMPTS=5
RATE_LIMIT_WINDOW=300
ACCOUNT_LOCKOUT_THRESHOLD=10
ACCOUNT_LOCKOUT_WINDOW=15
