# CUK-Admin - Configuration
# Copier en .env et modifier
# NE JAMAIS committer le fichier .env dans le dépôt

APP_ENV=development
APP_DEBUG=true

# Base de données (sqlite par défaut)
DB_DRIVER=sqlite
# DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cuk_admin
DB_USER=root
DB_PASSWORD=your_secure_password_here

# Redis (sessions, optionnel)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PREFIX=cuk_session:

# Maintenance
MAINTENANCE_MODE=false

# Sécurité
SESSION_LIFETIME=7200
RATE_LIMIT_ATTEMPTS=5
RATE_LIMIT_WINDOW=300
ACCOUNT_LOCKOUT_THRESHOLD=10
